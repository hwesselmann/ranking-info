<beanio xmlns="http://www.beanio.org/2012/03"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.beanio.org/2012/03 http://www.beanio.org/2012/03/mapping.xsd">

    <stream name="rankingFile" format="csv">
        <record name="player" class="de.hdawg.tennis.rankinginfo.model.Player">
            <field name="currentRanking" />
            <field name="lastName" />
            <field name="firstName" />
            <field name="nationality" />
            <field name="dtbIdAndFederation" />
            <field name="club" />
            <field name="currentScore" />
        </record>
    </stream>

</beanio>