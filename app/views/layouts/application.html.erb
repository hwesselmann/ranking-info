<!DOCTYPE html>
<html lang="de">
  <head>
    <title><%= full_title(yield(:title)) %></title>
    <meta name="description" content="<%= yield(:meta_content) %>">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= render 'layouts/favicon' %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', media: 'all' %>
    <%= javascript_pack_tag 'application' %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.1/css/bulma.min.css">
    <script src="https://kit.fontawesome.com/8eb0664b18.js" crossorigin="anonymous"></script>
    <%= render 'layouts/shim' %>
  </head>
  <body>
    <div id="cookies-eu-banner" style="display: none;">
      Diese Webseite benutzt Cookies. Für weitere Informationen schaut bitte in den Bereich Datenschutz im Menüpunkt 'Über'.
      <button id="cookies-eu-accept">OK</button>
    </div>
    <%= render 'layouts/header' %>
    <div class="container is-fluid">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type %> mt-2"><%= message %></div>
      <% end %>
      <%= yield %>
      <%= debug(params) if Rails.env.development? %>
    </div>
  </body>
</html>
