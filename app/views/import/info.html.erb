<% provide(:title, "Status") %>
<div class="container">
  <p class="h2 text-left mt-3 mb-0">
    Status & Datenbestand
  </p>
  <span class="small text-muted">letztes Update: <%= @date_last_updated %></span>
  <p class="h5 text-left mt-3">
    Anzahl Datensätze im System
  </p>
  <table class="table table-sm table-striped mb-3">
    <thead class="thead-dark">
      <tr>
        <th class="center">Spielerinnen</th>
        <th class="center">Spieler</th>
        <th class="center">Einzelrankings</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="center"><%= @player_female_count %></td>
        <td class="center"><%= @player_male_count %></td>
        <td class="center"><%= @ranking_count %></td>
      <tr>
    </tbody>
  </table>

  <p class="h5 text-left mt-3">
    Verfügbare Quartale
    <span class="text-muted">
      <small><i>
        <br/>
        * Stichtag 31.12.
        ** Stichtag 31.03.
        *** Stichtag 30.06.
        **** Stichtag 30.09.
      </i></small>
    </span>
  </p>
  <table class="table table-sm table-striped mb-3">
    <thead class="thead-dark">
      <tr>
        <th class="center">Jahr</th>
        <th class="center">01.01.*</th>
        <th class="center">01.04.**</th>
        <th class="center">01.07.***</th>
        <th class="center">01.10.****</th>
      </tr>
    </thead>
    <tbody>
    <% @available_quarters.each do |y, q| %>
      <tr>
        <td class="center"><%= y.to_s %></td>
        <td class="center"><% if q.include? '01.01.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></td>
        <td class="center"><% if q.include? '01.04.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></td>
        <td class="center"><% if q.include? '01.07.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></td>
        <td class="center"><% if q.include? '01.10.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
