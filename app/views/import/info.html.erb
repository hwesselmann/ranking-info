<% provide(:title, "Status") %>
<div class="container">
  <p class="h2 text-left mt-3 mb-0">
    Status & Datenbestand
  </p>
  <span class="small text-muted">letztes Update: <%= @date_last_updated %></span>
  <p class="h5 text-left mt-3">
    Anzahl Datensätze im System
  </p>
  <div class="container">
    <div class="row justify-content-md-center text-white bg-dark font-weight-bold p-2">
      <div class="col-4 col-md-4 center">Spielerinnen</div>
      <div class="col-4 col-md-4 center">Spieler</div>
      <div class="col-4 col-md-4 center">Einzelrankings</div>
    </div>
    <div class="row justify-content-md-center mb-3 p-2">
      <div class="col-4 col-md-4 center"><%= @player_female_count %></div>
      <div class="col-4 col-md-4 center"><%= @player_male_count %></div>
      <div class="col-4 col-md-4 center"><%= @ranking_count %></div>
    </div>
  </div>

  <p class="h5 text-left mt-3">
    Verfügbare Quartale
    <span class="text-muted">
      <small><i>
        <br/>
        * Stichtag 31.12.
        ** Stichtag 31.03.
        *** Stichtag 30.06.
        **** Stichtag 30.09.
      </i></small>
    </span>
  </p>
  <div class="container mb-3">
    <div class="row justify-content-md-center text-white bg-dark font-weight-bold p-2">
      <div class="col-4 col-md-4 center">Jahr</div>
      <div class="col-2 col-md-2 center">Q1*</div>
      <div class="col-2 col-md-2 center">Q2**</div>
      <div class="col-2 col-md-2 center">Q3***</div>
      <div class="col-2 col-md-2 center">Q4****</div>
    </div>
    <% if @available_quarters.size.positive? %>
      <% @available_quarters.each do |y, q| %>
        <div class="row <%= 'striped' unless y.to_i.even? %> justify-content-md-center p-2">
          <div class="col-4 col-md-4 center"><%= y.to_s %></div>
          <div class="col-2 col-md-2 center"><% if q.include? '01.01.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></div>
          <div class="col-2 col-md-2 center"><% if q.include? '01.04.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></div>
          <div class="col-2 col-md-2 center"><% if q.include? '01.07.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></div>
          <div class="col-2 col-md-2 center"><% if q.include? '01.10.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %></div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
