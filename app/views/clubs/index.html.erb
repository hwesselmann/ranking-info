<% provide(:title, 'Vereinssuche') %>
<% provide(:meta_content, "Suche nach Vereinen mit Spielerinnen und Spielern auf der aktuellen Deutschen Tennis-Jugendrangliste.") %>
<div class="container">
  <p class="h2 text-left mt-3 mb-3">
    Vereinssuche
  </p>
  <%= form_tag(clubs_path, method: 'get', class: 'mb-3') do %>
  <div class="form-row">
    <div class="col-auto">
    <%= search_field_tag 'club', params[:club], class: 'form-control mb-2 mr-sm-3', placeholder: 'Vereinsname' %>
    </div>
    <div class="col-auto">
    <%= submit_tag 'suchen', class: 'btn btn-dark mb-2' %>
    </div>
  </div>
  <% end %>
</div>
<% if @clubs.present? %>
   <%= render 'clubs_result_list' %>
<% else %>
  <% if params[:commit] %>
    <div>Es wurden keine Vereine gefunden.</div>
  <% else %>
    <%= render 'search_intro' %>
  <% end %>
<% end %>
