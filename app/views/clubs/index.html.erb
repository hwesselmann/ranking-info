<% provide(:title, 'Vereinssuche') %>
<% provide(:meta_content, "Suche nach Vereinen mit Spielerinnen und Spielern auf der aktuellen Deutschen Tennis-Jugendrangliste.") %>
<div class="container">
  <h1 class="title is-3 has-text-left mb-3 mt-3">
    Vereinssuche
  </h1>
  <%= form_tag(clubs_path, method: 'get', class: 'mb-3') do %>
  <div class="field is-horizontal">
    <div class="control is-expanded mr-2">
      <%= search_field_tag 'club', params[:club], class: 'input is-small mb-2', placeholder: 'Vereinsname' %>
    </div>
    <div class="control">
      <%= submit_tag 'suchen', class: 'button is-link is-small mb-2 is-info' %>
    </div>
  </div>
  <% end %>
</div>
<% if @clubs.present? %>
   <%= render 'clubs_result_list' %>
<% else %>
  <% if params[:commit] %>
    <div>Es wurden keine Vereine gefunden.</div>
  <% else %>
    <%= render 'search_intro' %>
  <% end %>
<% end %>
