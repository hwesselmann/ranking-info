<div class="table-container">
  <table class="table is-striped">
    <thead>
      <tr>
        <th>Vereinsname</th>
        <th class="center">Anzahl Spieler</th>
      </tr>
    </thead>
    <tbody>
      <% @clubs.each do |club| %>
        <tr>
          <td><%= link_to club[:name], club_path(club[:name]), class: 'has-text-info' %></td>
          <td class="center"><%= club[:player_count] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
