<span class="title is-6"><br/>Verfügbare Daten</span>
<div class="container mt-3">
  <div class="columns has-text-white has-background-dark has-text-weight-bold">
    <div class="column is-4">Jahr</div>
    <div class="column is-2">Q1</div>
    <div class="column is-2">Q2</div>
    <div class="column is-2">Q3</div>
    <div class="column is-2">Q4</div>
  </div>
  <% @available_quarters.each do |y, q| %>
    <div class="columns">
      <div class="column is-4">
        <%= y.to_s %>
      </div>
      <div class="column is-2">
        <% if q.include? '01.01.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %>
      </div>
      <div class="column is-2">
        <% if q.include? '01.04.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %>
      </div>
      <div class="column is-2">
        <% if q.include? '01.07.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %>
      </div>
      <div class="column is-2">
        <% if q.include? '01.10.' %><span class="ri-icon-green"><i class="fas fa-check-circle"></i></span><% end %>
      </div>
    </div>
  <% end %>
</div>
