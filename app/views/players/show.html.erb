<% provide(:title, "Spielerprofil #{@player.firstname} #{@player.lastname}") %>
<% provide(:meta_content, "Spielerprofil mit Ranglistenverlauf für #{@player.firstname} #{@player.lastname}") %>
<div class="container">
  <h1 class="title is-4 has-text-left mb-3 mt-3">
   Spielerprofil
  </h1>
<div class="container">
  <div class="row">
    <div class="col-12">
    <%= image_pack_tag("#{@player.nationality.downcase}.svg", width: "35") %>
    <span class="h4 align-bottom"><%= @player.firstname %> <%= @player.lastname %></span>
    </div>
  </div>
  <div class="row">
    <div class="col-md-12">
      DTB-ID <i><%= @player.dtb_id %></i>
    </div>
    <div class="col-md-12 text-right">
        <b><%= link_to @player.club, club_path(@player.club), class: 'text-info' %></b> / <i><%= @player.federation %></i>
    </div>
  </div>
  <div class="row">
    <div class="col-md-6">
      <%= render 'player_current_ranking' %>
    </div>
    <div class="col-md-6">
      <%= render 'player_chart_current' %>
    </div>
  </div>
  <div class="row">
    <div class="col-md-6">
      <%= render 'player_chart_current_score' %>
    </div>
    <div class="col-md-6">
      <%= render 'player_clubs' %>
      <%= render 'player_available_data' %>
    </div>
  </div>
  <div class="row">
    <div class="col-md-12">
      <%= render 'player_chart_complete' %>
      <%= render 'player_chart_complete_score' %>
    </div>
  </div>
  <div class="row mb-3">
    <div class="col-md-12">
      <%= render 'player_complete_rankings_youth' %>
    </div>
  </div>
</div>
