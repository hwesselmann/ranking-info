<table class="table table-striped">
  <thead class="thead-dark">
    <tr>
      <th>DTB-ID</th>
      <th>Nachname, Vorname</th>
      <th class="center">Nationalität</th>
      <th>Verein</th>
      <th class="center">Verband</th>
    </tr>
  </thead>
  <tbody>
    <% @players.each do |player| %>
      <tr>
        <td><%= link_to player.dtb_id, player_path(player.dtb_id) %></td>
        <td><%= player.lastname %>, <%= player.firstname %></td>
        <td class="center"><%= player.nationality %></td>
        <td><%= player.club %></td>
        <td class="center"><%= player.federation %></td>
      </tr>
    <% end %>
  </tbody>
</table>
